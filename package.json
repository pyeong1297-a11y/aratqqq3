{
  "name": "aratqqq3-backtester",
  "version": "0.1.0",
  "private": true,
  "description": "Backtesting toolkit for the kept TQQQ baseline, BULZ, and ISA TIGER 418660 strategies.",
  "type": "module",
  "scripts": {
    "fetch-data": "node src/fetch-data.js all",
    "help": "node src/cli.js --help",
    "check-data": "node src/cli.js check-data all",
    "run": "node src/cli.js run all",
    "run:tqqq": "node src/cli.js run us-tqqq",
    "run:tqqq:growth": "node src/cli.js run us-tqqq-growth",
    "run:tqqq:balance": "node src/cli.js run us-tqqq-balance",
    "run:tqqq:defense": "node src/cli.js run us-tqqq-defense",
    "run:snowball": "node src/cli.js run us-snowball-optimized",
    "run:snowball:basic": "node src/cli.js run us-snowball-basic",
    "run:snowball:optimized": "node src/cli.js run us-snowball-optimized",
    "run:snowball:rounded": "node src/cli.js run us-snowball-rounded",
    "run:bulz": "node src/cli.js run us-bulz",
    "run:isa": "node src/cli.js run isa-kodex --save results/isa-tiger-latest.json",
    "run:isa:console": "node src/cli.js run isa-kodex",
    "app": "node app.js",
    "app:export": "node app.js --export-static"
  }
}
